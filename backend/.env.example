# Server
PORT=3000
NODE_ENV=development

# CORS (frontend origin; production: your frontend URL)
CORS_ORIGIN=http://localhost:5173

# Database (SQLite file path; default: backend/data/coreinventory.db)
# DATABASE_PATH=./data/coreinventory.db

# Optional auth (set AUTH_ENABLED=true to require login)
# AUTH_ENABLED=false
# JWT_SECRET=your-secret-min-32-chars-for-production
# JWT_EXPIRES=7d
# REFRESH_WINDOW_DAYS=7
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
# For production: set ADMIN_PASSWORD_HASH to bcrypt hash of admin password (do not use ADMIN_PASSWORD)
# ADMIN_PASSWORD_HASH=

# Email (for forgot-password OTP; optional in dev — OTP is returned in API response when NODE_ENV !== production)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=
